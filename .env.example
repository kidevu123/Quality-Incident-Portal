# =============================================================================
# Nexus Resolve — production / Docker (.env in project root; never commit)
# Copy: cp .env.example .env && chmod 600 .env
# =============================================================================

# --- Django (required in production) ---
DJANGO_SECRET_KEY=replace-with-python-c-secrets-token-urlsafe-50
DJANGO_DEBUG=false
# Comma-separated; include your public hostname and Docker service names as needed
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx,your-vm-hostname,your.domain.com

# Database URL — hostname MUST be `db` when using docker-compose.yml
DATABASE_URL=postgres://nexus:CHANGE_THIS_DB_PASSWORD@db:5432/nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD
POSTGRES_DB=nexus

# Celery (overridden in compose to redis://redis:6379/0; values here are for reference)
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# HTTP port published on the host (compose maps host:${NEXUS_HTTP_PORT} -> nginx:80)
NEXUS_HTTP_PORT=80

# TLS / cookies — enable when users access over HTTPS (terminating TLS at Nginx or a reverse proxy)
SECURE_SSL_REDIRECT=false
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
BEHIND_TLS_PROXY=false
# If SESSION_COOKIE_SECURE=true but you also use plain http:// on a LAN IP, login will loop unless you
# set this to true (cookies work over HTTP) or only sign in via HTTPS.
DJANGO_HTTP_SAFE_COOKIES=false

# Footer / ops (optional; defaults to config/version.py)
# NEXUS_APP_VERSION=1.0.0

# When using HTTPS, set your public origin(s) (comma-separated)
CSRF_TRUSTED_ORIGINS=https://your.domain.com
CORS_ALLOWED_ORIGINS=https://your.domain.com

# Telegram — optional: notify when a claim is submitted via /portal/claims/new/
# Full setup: docs/TELEGRAM.md
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_BOT_USERNAME=YourBotName
# TELEGRAM_CHAT_IDS=123456789,-1001234567890
# TELEGRAM_WEBHOOK_SECRET=long-random-string-matching-setWebhook
# REDIS_CACHE_URL=redis://redis:6379/2

# Email (optional)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=nexus@your.domain.com

# Zoho (optional — leave empty for simulated SO in dev/demo)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
ZOHO_API_BASE=https://www.zohoapis.com
ZOHO_BOOKS_ORG_ID=
ZOHO_REPLACEMENT_SO_THRESHOLD=5000

HOT_BATCH_CLAIM_THRESHOLD=3
AUTO_APPROVE_MAX_AMOUNT=250
