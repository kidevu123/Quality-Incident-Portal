# Django
DJANGO_SECRET_KEY=change-me-use-long-random-string
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=nexus.example.com,127.0.0.1

# Database (PostgreSQL in production)
DATABASE_URL=postgres://nexus:nexus@db:5432/nexus

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# CORS (API / future SPA)
CORS_ALLOWED_ORIGINS=https://nexus.example.com
CSRF_TRUSTED_ORIGINS=https://nexus.example.com

# Zoho (never commit real secrets)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
ZOHO_API_BASE=https://www.zohoapis.com
ZOHO_BOOKS_ORG_ID=
ZOHO_REPLACEMENT_SO_THRESHOLD=5000

# Policy
HOT_BATCH_CLAIM_THRESHOLD=3
AUTO_APPROVE_MAX_AMOUNT=250

# Dev only: set USE_SQLITE=1 in development settings override
# USE_SQLITE=1
